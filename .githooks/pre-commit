#!/bin/bash
# Pre-commit hook: runs linters as warnings only (never blocks commits)

echo "========================================"
echo "  Running pre-commit lint checks..."
echo "========================================"
echo ""

WARNINGS=0

# --- Python: black, isort, autoflake ---
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$PYTHON_FILES" ]; then
  echo "[Python] Checking staged .py files..."

  # Black
  if command -v black &>/dev/null; then
    if ! black --check --quiet $PYTHON_FILES 2>/dev/null; then
      echo "  ⚠ black: some files need formatting (run 'black .')"
      WARNINGS=1
    else
      echo "  ✓ black: all good"
    fi
  else
    echo "  ⚠ black not found, skipping"
  fi

  # isort
  if command -v isort &>/dev/null; then
    if ! isort --check-only --quiet $PYTHON_FILES 2>/dev/null; then
      echo "  ⚠ isort: import order issues (run 'isort .')"
      WARNINGS=1
    else
      echo "  ✓ isort: all good"
    fi
  else
    echo "  ⚠ isort not found, skipping"
  fi

  # autoflake
  if command -v autoflake &>/dev/null; then
    if ! autoflake --check --remove-all-unused-imports $PYTHON_FILES 2>/dev/null; then
      echo "  ⚠ autoflake: unused imports detected (run 'autoflake --in-place --remove-all-unused-imports .')"
      WARNINGS=1
    else
      echo "  ✓ autoflake: all good"
    fi
  else
    echo "  ⚠ autoflake not found, skipping"
  fi
else
  echo "[Python] No staged .py files, skipping."
fi

echo ""

# --- Frontend: eslint ---
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/src/.*\.\(ts\|tsx\)$' || true)

if [ -n "$FRONTEND_FILES" ]; then
  echo "[Frontend] Checking staged .ts/.tsx files..."

  if [ -f "frontend/node_modules/.bin/eslint" ]; then
    if ! (cd frontend && npx eslint --no-error-on-unmatched-pattern $FRONTEND_FILES 2>/dev/null); then
      echo "  ⚠ eslint: issues found (run 'cd frontend && npm run lint')"
      WARNINGS=1
    else
      echo "  ✓ eslint: all good"
    fi
  else
    echo "  ⚠ eslint not installed, skipping (run 'cd frontend && npm install')"
  fi
else
  echo "[Frontend] No staged .ts/.tsx files, skipping."
fi

echo ""

if [ $WARNINGS -eq 1 ]; then
  echo "========================================"
  echo "  Lint warnings found (commit proceeding)"
  echo "========================================"
else
  echo "========================================"
  echo "  All lint checks passed!"
  echo "========================================"
fi

# Always exit 0 — never block the commit
exit 0
